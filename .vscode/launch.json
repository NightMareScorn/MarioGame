{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MarioGame (Launch Game)",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "Build MarioGame",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": [
        "/c",
        "start \"\" \"${workspaceFolder}/x64/Debug/MarioGame.exe\""
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/SE102/MarioGame",
      "program": "d:/SE102/MarioGame/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}